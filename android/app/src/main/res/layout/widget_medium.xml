<?xml version="1.0" encoding="utf-8"?>
<!-- android/app/src/main/res/layout/widget_medium.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💰 FinanceKu"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_last_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textColor="#60FFFFFF"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Total Saldo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Saldo"
        android:textColor="#80FFFFFF"
        android:textSize="10sp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/widget_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rp 0"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#30FFFFFF"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp" />

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Pemasukan -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ Pemasukan"
                android:textColor="#80FFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_income"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="#69DB7C"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Pengeluaran Bulan -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↑ Pengeluaran"
                android:textColor="#80FFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="#FF6B6B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Pengeluaran Hari ini -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_today_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Hari ini"
                android:textColor="#80FFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_today_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="#FFA94D"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Quick Add Button -->
        <LinearLayout
            android:id="@+id/widget_add_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_button_bg"
            android:padding="8dp"
            android:layout_gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catat"
                android:textColor="#CCFFFFFF"
                android:textSize="8sp"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>

    <!-- Month label -->
    <TextView
        android:id="@+id/widget_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maret 2026"
        android:textColor="#50FFFFFF"
        android:textSize="9sp"
        android:layout_marginTop="6dp" />

</LinearLayout>